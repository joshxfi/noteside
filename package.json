{
  "name": "noteside",
  "version": "0.1.0",
  "private": true,
  "description": "Noteside — notes for keyboard people. Offline, local-first, vim-first notes.",
  "license": "MIT",
  "scripts": {
    "dev": "turbo run dev --filter=@noteside/landing --filter=@noteside/desktop",
    "dev:desktop": "turbo run dev --filter=@noteside/desktop",
    "dev:landing": "turbo run dev --filter=@noteside/landing",
    "dev:brand": "turbo run dev --filter=@noteside/brand",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:rust": "turbo run test:rust",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "tauri": "pnpm --filter @noteside/desktop tauri",
    "demo:build": "pnpm --filter @noteside/desktop build:web && rm -rf apps/landing/public/demo && cp -r apps/desktop/dist apps/landing/public/demo"
  },
  "devDependencies": {
    "oxfmt": "0.54.0",
    "oxlint": "^1.69.0",
    "turbo": "^2.5.0",
    "typescript": "^5.8.0"
  },
  "engines": {
    "node": ">=24",
    "pnpm": ">=11"
  },
  "packageManager": "pnpm@11.7.0"
}
