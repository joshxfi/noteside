{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Noteside",
  "version": "0.1.0",
  "identifier": "dev.noteside.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev:web",
    "beforeBuildCommand": "pnpm build:web"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Noteside",
        "width": 1180,
        "height": 800,
        "minWidth": 720,
        "minHeight": 520,
        "decorations": false,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Productivity",
    "shortDescription": "Notes for keyboard people.",
    "longDescription": "Noteside is an offline, local-first notebook with first-class vim keybindings. Your notes are plain Markdown files on your disk.",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.png"]
  }
}
